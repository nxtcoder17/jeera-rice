theme = base16.conf

font-family = "Recursive Mono Casual Static"

# pick your variations HERE: https://www.recursive.design/
# casual
font-variation = casl=1
# weight
font-variation = wght=500
# cursive
font-variation = CRSV=1 
font-size = 12

# choose font features by [reading here](https://www.recursive.design/assets/process-img/recursive-ot_features.png)
font-feature = +dlig
font-feature = +ss01
font-feature = +ss02
font-feature = +ss03
font-feature = +ss04
font-feature = +ss05
font-feature = +ss06
font-feature = +ss07
font-feature = +ss08
font-feature = +ss09
font-feature = +ss12
font-feature = +calt
font-feature = -ss10 
adjust-cell-height = 10%

shell-integration-features = no-cursor
 
confirm-close-surface = false
window-decoration = false

window-padding-balance = true

background-opacity=0.98
background-blur=50
