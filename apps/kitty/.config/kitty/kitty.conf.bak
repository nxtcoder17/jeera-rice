# vim: set ft=conf:

linux_display_server wayland

# include ./fonts/monaspace-radon.conf
# include ./fonts/comic-code-ligatures.conf
# include ./fonts/operator-mono.conf
# include ./fonts/monolisa.conf
# include ./fonts/agave.conf
# include ./fonts/iosevka.conf

# include ./fonts/serious-shanns.conf
# include ./fonts/serious-shanns.conf
# include ./fonts/mononoki.conf
include ./fonts/recursive.conf
include ./fonts/nerd-fonts-symbol-map.conf

# include ./fonts/comic-shanns-mono.conf

disable_ligatures never

shell fish

# TERM env
term xterm-256color

background_opacity 1

# INFO: background image must be in PNG format
# background_image /var/home/nxtcoder17/me/jeera-rice/wallpapers/night-fog.png
# background_image /var/home/nxtcoder17/Downloads/white-paper.png
background_image ~/.cache/kitty-background.png
# background_image ~/Downloads/10148867.png
# background_image ~/me/jeera-rice/wallpapers/paper-backgrounds/paper-pixmap.png
# background_image /var/home/nxtcoder17/Downloads/black-paper.png
# background_image /var/home/nxtcoder17/Downloads/darkblue-paper.png
# background_image /var/home/nxtcoder17/me/jeera-rice/wallpapers/paper-backgrounds/dots-catalina-blue-102b6f.png
# background_image /var/home/nxtcoder17/Downloads/tmp-bg.png
# background_image /var/home/nxtcoder17/Downloads/x.png

# background_image /var/home/nxtcoder17/Downloads/wp-3-min.png
# background_image /var/home/nxtcoder17/Downloads/wp-4.png

# [source](https://sw.kovidgoyal.net/kitty/conf/#opt-kitty.background_image_layout)
# background_image_layout tiled
# background_image_layout mirror-tiled


# stops asking for confirmation on close
confirm_os_window_close 0

enable_audio_bell no

# INFO: DO NOT use quotes to wrap theme name, kitty will just not work
include ./themes/light-or-dark-theme.conf
# include ./themes/dayfox.conf

# # background #E8EBF5
# # background #f0f5f9
# background #ebeff2
# background #F9FBFF  # paper

# sourced from https://github.com/YorickPeterse/vim-paper

# kitty_mod alt
# map kitty_mod+t new_tab_with_cwd

map ctrl+shift+w no_op

background_tint 0.30
shell_integration no-sudo


# BEGIN_KITTY_THEME
# Kanagawa_light
include current-theme.conf
# END_KITTY_THEME