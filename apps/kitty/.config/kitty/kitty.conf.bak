# vim: set ft=conf:

#linux_display_server wayland

# include ./fonts/monaspace-radon.conf
# include ./fonts/comic-code-ligatures.conf
# include ./fonts/operator-mono.conf
# include ./fonts/monolisa.conf
# include ./fonts/agave.conf
# include ./fonts/iosevka.conf
include ./fonts/nxtfont.conf

# include ./fonts/serious-shanns.conf
# include ./fonts/mononoki.conf
# include ./fonts/recursive.conf
# include ./fonts/monaspace-krypton.conf
# include ./fonts/kode-mono.conf
# include ./fonts/lotion.conf
# include ./fonts/terminus.conf
# include ./fonts/zenbones-brainy.conf
# include ./fonts/commit-mono.conf
include ./fonts/nerd-fonts-symbol-map.conf

allow_remote_control socket-only                                                              
listen_on unix:/tmp/kitty-{kitty_pid}

# text_composition_strategy legacy
hide_window_decorations yes
repaint_delay 2
# sync_to_monitor no

# cursor_trail 50
# cursor_trail_decay 0.1 0.3

# include ./fonts/comic-shanns-mono.conf

disable_ligatures never


# TERM env
# term xterm-255color
# term xterm-kitty

background_opacity 1
window_margin_width 1 2 0 2

window_border_width 2pt
adjust_line_height 0

window_padding_width 2
single_window_margin_width 2
single_window_padding_width -1

# INFO: background image must be in PNG format

# [source](https://sw.kovidgoyal.net/kitty/conf/#opt-kitty.background_image_layout)
# background_image_layout tiled
# background_image_layout mirror-tiled

# stops asking for confirmation on close
confirm_os_window_close 0

# bells
enable_audio_bell no
visual_bell_duration 0
# visual_bell_color none
window_alert_on_bell no

# INFO: DO NOT use quotes to wrap theme name, kitty will just not work
# include ~/.colorscheme.d/kitty/theme.conf
include ./themes/theme.conf

shell_integration no-sudo

cursor_shape block

map ctrl+shift+w no_op

shell bash

# [source]https://www.reddit.com/r/neovim/comments/mbj8m5/how_to_setup_ctrlshiftkey_mappings_in_neovim_and/?utm_source=share&utm_medium=web3x&utm_name=web3xcss&utm_term=1&utm_content=share_button
# [Also check](https://en.wikipedia.org/wiki/List_of_Unicode_characters#Latin_script)
map ctrl+shift+j send_text all \x1b[74;5u
map ctrl+shift+k send_text all \x1b[75;5u

include kitty_$KITTY_OS.conf 


tab_bar_min_tabs 2
tab_bar_edge top

# clear_all_shortcuts yes
include ./kitty_like_tmux.conf
