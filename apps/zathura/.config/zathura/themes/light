# Zathura Light Theme

set default-bg "#1f1f28"
set default-fg "#dcd7ba"

set statusbar-bg "#2a2a37"
set statusbar-fg "#dcd7ba"

set inputbar-bg "#2a2a37"
set inputbar-fg "#dcd7ba"

set notification-bg "#2a2a37"
set notification-fg "#dcd7ba"
set notification-error-bg "#e46876"
set notification-error-fg "#1f1f28"
set notification-warning-bg "#e6c384"
set notification-warning-fg "#1f1f28"

set highlight-color "#e6c384"
set highlight-active-color "#7e9cd8"

set completion-bg "#2a2a37"
set completion-fg "#dcd7ba"
set completion-highlight-bg "#363646"
set completion-highlight-fg "#dcd7ba"
set completion-group-bg "#2a2a37"
set completion-group-fg "#7e9cd8"

set render-loading-bg "#1f1f28"
set render-loading-fg "#727169"

# Recolor document to match theme
set recolor true
set recolor-lightcolor "#1f1f28"
set recolor-darkcolor "#dcd7ba"
set recolor-keephue true
