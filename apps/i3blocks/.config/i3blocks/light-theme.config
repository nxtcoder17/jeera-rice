# vim: set filetype=i3blocks:

align=center
separator=false
#background=#1E3440
background=#eff1f5
foreground=#184747
separator_block_width=15
markup=pango

[date]
command=echo -e "<span fgcolor='#184747'><b> $( ([[ $BLOCK_BUTTON -eq 1 ]] && date) || date '+%a %I:%M %p') </b></span>"
border=#184747
border_top=1
border_left=0
border_right=0
border_bottom=0
interval=5

[battery]
interval=2
command=echo -e "<span fgcolor='#184747'><b>$( acpi | awk -F, '{print $2}' | tr -d ' ' )</b></span>"
border=#4b57e3
label=<span color="#184747"> POW </span>
border_top=1
border_right=0
border_bottom=0
border_left=0

[wifi]
command=iwgetid -r | tr '\n' ' ' && grep $(iwgetid -m | awk '{ printf "%s", $1 }') /proc/net/wireless | awk '{ printf "%i%\n", int($3 * 100 / 70) }'
instance=wlp11s0f3u1
interval=5
label=<span color="#184747">  </span>
border=#184747
border_top=1
border_right=0
border_bottom=0
border_left=0

[home]
command=df -h /home | awk 'FNR==2 { gsub(/[A-Za-z]/, ""); printf "%i<span color=\"#184747\">G</span>\n", $4 }'
interval=3
label=<span color="#184747"> </span>
border=#184747
border_top=1
border_right=0
border_bottom=0
border_left=0

[cpu]
command=mpstat | grep -i all | awk '{print $4}'
interval=2
label=<span color="#184747"> CPU </span>
border=#184747
border_top=1
border_right=0
border_bottom=0
border_left=0

[memory]
command=free --giga | awk 'FNR==2{ printf "%i<span color=\"#184747\">G</span>\n", $7 }'
interval=2
label=<span color="#184747"> MEM </span>
border=#184747
border_top=1
border_right=0
border_bottom=0
border_left=0

[volume]
command=echo -e "<span color='#8061ab'>$(pamixer --get-volume) </span>"
interval=1
label=<span color="#8061ab">  </span>
border=#8061ab
border_top=1
border_right=0
border_bottom=0
border_left=0

