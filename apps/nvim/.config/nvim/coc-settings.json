// vim: set ft=jsonc:
{

  // nxtcoder17's customstiations
  "languageserver": {
        "golang": {
          "command": "gopls",
          "rootPatterns": ["go.mod", ".vim/", ".git/", ".hg/"],
          "filetypes": ["go"]
        }
    },

  "coc.source.rg.enable": true,

  "eslint.validate": ["typescript"],
  "eslint.lintTask.options": [".", "--ext", ".ts"],
  "sumneko-lua.enableNvimLuaDev": true,
  "javascript.format.semicolons": "remove",
  "typescript.format.semicolons": "remove",
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.preferences.importModuleSpecifierEnding": "minimal",
  "typescript.preferences.quoteStyle": "single",
  "typescript.format.insertSpaceAfterFunctionKeywordForAnonymousFunctions": false,
  "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,

  "suggest.noselect": true,
  "coc.preferences.messageLevel": "warning",
  "coc.preferences.maxFileSize": "1MB",
  "coc.preferences.enableMarkdown": true,

  "diagnostic.hintSign": "✹",
  "diagnostic.errorSign": "✘",
  "diagnostic.warningSign": "",
  "diagnostic.infoSign": "",
  "codeLens.enable": false,
  "codeLens.separator": " ",
  "codeLens.subseparator": " | ",
  "inlayHint.typeSeparator": "‣ ",
  "inlayHint.parameterSeparator": "‣ ",
  "notification.disabledProgressSources": [ "*" ],
  "diagnostic.virtualText": true,
  "diagnostic.virtualTextCurrentLineOnly": false,
  "diagnostic.virtualTextLineSeparator": ". ",
  "diagnostic.virtualTextPrefix": " ",
  "diagnostic.checkCurrentLine": true,
  "diagnostic.messageTarget": "float",

  "python.formatting.provider": "autopep8",
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.typeCheckingMode": "basic",
  "python.formatting.autopep8Path": "/opt/homebrew/bin/autopep8",
  "python.linting.pylintEnabled": true,
  "python.linting.enabled": true,
  "python.linting.pylintArgs": [
    "--generate-members"
  ],
  "python.analysis.useLibraryCodeForTypes": true,
  "python.pythonPath": "python",

  "semanticTokens.enable": true,
  "semanticTokens.highlightPriority": 4096,

  "rpc.enabled": true,
  "rpc.idleText": "Crying Inside",
  "rpc.buttonInactiveUrl": "https://www.youtube.com/watch?v=dQw4w9WgXcQ",
  "rpc.detailsEditing": "Workspace: {workspace_folder}",
  "rpc.detailsViewing": "In {workspace_folder}",
  "rpc.lowerDetailsNotFound": "🦀",
  "rpc.lowerDetailsEditing": "Editing: {file_name}",

  "sumneko-lua.enableNvimLuaDev": true,
  "Lua.semantic.enable": true,
  "Lua.hint.paramName": "All",
  "Lua.hint.enable": true,
  "Lua.hint.setType": true,
  "Lua.hint.paramType": true,
  "coc.source.word.filetypes": [
    "norg",
    "text",
    "mail"
  ],
  "suggest.snippetIndicator": " \ue796",
  "suggest.completionItemKindLabels": {
    "keyword": "\uf1de",
    "variable": "\ue79b",
    "value": "\uf89f",
    "operator": "\u03a8",
    "function": "\u0192",
    "reference": "\ufa46",
    "constant": "\uf8fe",
    "method": "\uf09a",
    "struct": "\ufb44",
    "class": "\uf0e8",
    "interface": "\uf417",
    "text": "\ue612",
    "enum": "\uf435",
    "enumMember": "\uf02b",
    "module": "\uf40d",
    "color": "\ue22b",
    "property": "\ue624",
    "field": "\uf9be",
    "unit": "\uf475",
    "event": "\ufacd",
    "file": "\uf723",
    "folder": "\uf114",
    "snippet": "\ue60b",
    "typeParameter": "\uf728",
    "default": "\uf29c"
  },
  "snippets.ultisnips.enable": true,
}
